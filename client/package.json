{
  "name": "webdesk-ui",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "main": "./dist/library/index.js",
  "module": "./dist/library/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/library/index.js",
      "default": "./dist/library/index.js"
    }
  },
  "files": [
    "dist/library",
    "index.d.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:lib": "run-s build:lib:bundle build:lib:types",
    "build:lib:bundle": "vite build --mode library",
    "build:lib:types": "vue-tsc -p tsconfig.lib.json",
    "prepack": "npm run build:lib",
    "prepare": "npm run build:lib",
    "preview": "vite preview",
    "build-only": "vite build",
    "docker:package": "node ./scripts/docker-package.mjs",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "mcp": "ruler apply",
    "mcp:revert": "ruler revert"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.9",
    "@mdi/font": "7.4.47",
    "date-fns": "^4.1.0",
    "pinia": "^3.0.4",
    "uuid": "^13.0.0",
    "vue-i18n": "^11.2.7"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vuetify": "^4.0.0"
  },
  "devDependencies": {
    "@intellectronica/ruler": "^0.3.18",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.0.5",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-config-vuetify": "^4.3.4",
    "npm-run-all2": "^8.0.4",
    "sass-embedded": "^1.97.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-fonts": "^1.4.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.26",
    "vue-tsc": "^3.2.0",
    "vuetify": "^4.0.0"
  }
}
